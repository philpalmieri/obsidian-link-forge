{
	"name": "obsidian-link-forge",
	"version": "1.0.4",
	"description": "Auto-creates linked files when they don't exist, in real-time.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "vitest run",
		"test:watch": "vitest",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"author": "Phil Palmieri",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.1",
		"@eslint/js": "10.0.1",
		"@eslint/json": "^1.2.0",
		"@types/node": "^25.6.0",
		"esbuild": "0.28.0",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.5.0",
		"jiti": "2.6.1",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.59.1",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
